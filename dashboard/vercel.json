{
  "rewrites": [
// 레거시 /record/api 프록시 삭제 (FASTAPI 백엔드가 현재 없으므로 주석 처리)
//   {
//     "source": "/record/api/:path*",
//     "destination": "https://YOUR-FASTAPI-BACKEND-URL/record/api/:path*"
//   },
    {
      "source": "/book/:path*",
      "destination": "https://tools4thept-book.vercel.app/book/:path*"
    },
    {
      "source": "/book",
      "destination": "https://tools4thept-book.vercel.app/book"
    },
    {
      "source": "/record/:path*",
      "destination": "https://tools4thept-book.vercel.app/record/:path*"
    },
    {
      "source": "/dashboard/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/dashboard/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
